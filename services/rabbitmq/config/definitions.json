{
  "rabbit_version": "3.12.0",
  "rabbitmq_version": "3.12.0",
  "product_name": "RabbitMQ",
  "product_version": "3.12.0",
  "users": [],
  "vhosts": [
    {
      "name": "/"
    }
  ],
  "permissions": [],
  "topic_permissions": [],
  "parameters": [],
  "global_parameters": [
    {
      "name": "cluster_name",
      "value": "dashcam-cluster"
    }
  ],
  "policies": [],
  "queues": [
    {
      "name": "worker_registration",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "worker_heartbeat",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "processing_progress",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "processing_complete",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "processing_errors",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "exchanges": [
    {
      "name": "dashcam_exchange",
      "vhost": "/",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    }
  ],
  "bindings": [
    {
      "source": "dashcam_exchange",
      "vhost": "/",
      "destination": "worker_registration",
      "destination_type": "queue",
      "routing_key": "worker.registration",
      "arguments": {}
    },
    {
      "source": "dashcam_exchange",
      "vhost": "/",
      "destination": "worker_heartbeat",
      "destination_type": "queue",
      "routing_key": "worker.heartbeat",
      "arguments": {}
    },
    {
      "source": "dashcam_exchange",
      "vhost": "/",
      "destination": "processing_progress",
      "destination_type": "queue",
      "routing_key": "progress.#",
      "arguments": {}
    },
    {
      "source": "dashcam_exchange",
      "vhost": "/",
      "destination": "processing_complete",
      "destination_type": "queue",
      "routing_key": "result.complete",
      "arguments": {}
    },
    {
      "source": "dashcam_exchange",
      "vhost": "/",
      "destination": "processing_errors",
      "destination_type": "queue",
      "routing_key": "result.error",
      "arguments": {}
    }
  ]
}